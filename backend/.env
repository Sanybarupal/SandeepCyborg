# Sandeep Clone — Environment Variables
# Yeh file PRIVATE hai — .gitignore mein daalna na bhulen

# ─── OpenAI (GPT-4) ──────────────────────────────
# Agar key nahi hai toh mock mode mein chalega
OPENAI_API_KEY=

# ─── ElevenLabs (Voice Clone) ────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── Database ────────────────────────────────────
# Default: SQLite (local file)
DATABASE_URL=sqlite:///./sandeep_ai.db

# ─── App Settings ────────────────────────────────
AI_MODEL=gpt-4o
FRONTEND_URL=http://localhost:3000
